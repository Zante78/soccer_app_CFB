# Environment Variables Template
# Copy to .env and fill with actual values

# ===== SUPABASE =====
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ===== DFBNET (RPA Bot) =====
DFBNET_USER=your-dfbnet-username
DFBNET_PASSWORD=your-dfbnet-password

# ===== EMAIL (2FA OTP Retrieval) =====
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your-email@example.com
IMAP_PASSWORD=your-app-password

# ===== PAYMENT =====
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-secret
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id

# ===== EMAIL SERVICE (Transactional) =====
RESEND_API_KEY=re_your_api_key

# ===== n8n =====
N8N_SECRET_TOKEN=your-random-secret-token-min-32-chars
N8N_WEBHOOK_URL=http://localhost:5678

# ===== ENCRYPTION & SECURITY =====
ENCRYPTION_KEY=your-random-encryption-key-32-chars

# ===== RPA SETTINGS =====
PLAYWRIGHT_HEADED=false
VISUAL_DIFF_TOLERANCE=0.002
SCREENSHOT_BASELINE_PATH=./apps/rpa-bot/baselines
