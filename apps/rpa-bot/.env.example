# Server Configuration
SERVER_PORT=3001
BOT_API_KEY=dev-secret-key
BOT_MODE=mock  # mock | live

# Supabase Configuration
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# DFBnet Credentials (Bot Account) - only needed for BOT_MODE=live
DFBNET_USERNAME=your_dfbnet_username
DFBNET_PASSWORD=your_dfbnet_password
DFBNET_BASE_URL=https://www.dfbnet.org

# Bot Configuration
BOT_HEADLESS=true
BOT_SCREENSHOT_DIR=./screenshots
BOT_BASELINE_DIR=./baselines
BOT_MAX_RETRIES=3
BOT_TIMEOUT_MS=30000

# Mock Bot Configuration
MOCK_SUCCESS_RATE=0.85
MOCK_DELAY_MS=3000

# Visual Regression
VISUAL_DIFF_THRESHOLD=0.002

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/bot.log
